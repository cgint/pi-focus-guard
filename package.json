{
  "name": "pi-focus-guard",
  "version": "0.2.0",
  "description": "Pi extension that groups discuss, write, and commit guards under focus-prefixed commands.",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/cgint/pi-focus-guard.git"
  },
  "author": "cgint",
  "publishConfig": {
    "registry": "https://registry.npmjs.org/"
  },
  "license": "MIT",
  "keywords": [
    "pi-package",
    "pi",
    "coding-agent",
    "extension",
    "focus",
    "write-protection",
    "discussion",
    "commit-guard"
  ],
  "files": [
    "index.ts",
    "src",
    "README.md",
    "LICENSE"
  ],
  "pi": {
    "extensions": [
      "./index.ts"
    ]
  },
  "type": "module",
  "dependencies": {
    "unbash": "^4.0.3"
  },
  "peerDependencies": {
    "@earendil-works/pi-coding-agent": ">=0.74.0",
    "@earendil-works/pi-tui": "*",
    "@sinclair/typebox": "*"
  },
  "scripts": {
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "precommit": "tsc --noEmit && npm run test && npm audit --audit-level=moderate"
  },
  "devDependencies": {
    "@earendil-works/pi-coding-agent": "^0.81.1",
    "@earendil-works/pi-tui": "^0.81.1",
    "@sinclair/typebox": "^0.34.52",
    "@types/node": "^26.1.1",
    "typescript": "^7.0.2",
    "vitest": "^4.1.10"
  },
  "overrides": {}
}
